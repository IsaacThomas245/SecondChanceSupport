							"    pm.expect(jsonData).to.have.property(\"latitude\");\r",
							"    pm.expect(jsonData).to.have.property(\"longitude\");\r",
							"    pm.expect(jsonData).to.have.property(\"typeviolent\");\r",
							"    pm.expect(jsonData).to.have.property(\"typeproperty\");\r",
							"    pm.expect(jsonData).to.have.property(\"typedrug\");\r",
							"    pm.expect(jsonData).to.have.property(\"typeother\");\r",
							"    pm.expect(jsonData).to.have.property(\"typetotal\");\r",
							"});\r",
							"\r",
							"pm.test(\"Testing Get County Id of 1\", function() {\r",
							"    const jsonData = pm.response.json();\r",
							"\r",
							"    const fieldToExpected = {\r",
							"        \"name\": \"Hunt\", \r",
							"        \"population\": 101596,\r",
							"        \"typeviolent\": 53,\r",
							"        \"typedrug\": 108, \r",
							"        \"typeother\": 70, \r",
							"        \"typeproperty\": 59, \r",
							"        \"typetotal\": 290, \r",
							"        \"population_rank\": 41\r",
							"    };\r",
							"\r",
							"    for(const field in fieldToExpected) {\r",
							"        pm.expect(jsonData[field]).to.equals(fieldToExpected[field]);\r",
							"    }\r",
							"});"
						],
						"type": "text/javascript"
					}
				}
